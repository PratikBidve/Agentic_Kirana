NODE_ENV=development

# PostgreSQL — use Neon connection string for production (Cloudflare-compatible)
# For local dev: postgresql://postgres:postgres@localhost:5432/kirana
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kirana

# Redis — local Docker or Upstash for production
REDIS_URL=redis://localhost:6379

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Better Auth
BETTER_AUTH_SECRET=your_random_secret_min_32_chars
BETTER_AUTH_URL=http://localhost:8787
